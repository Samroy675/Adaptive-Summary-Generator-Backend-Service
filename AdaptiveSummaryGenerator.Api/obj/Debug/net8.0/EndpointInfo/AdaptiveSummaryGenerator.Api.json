{
  "openapi": "3.0.1",
  "info": {
    "title": "AdaptiveSummaryGenerator.Api",
    "description": "Adaptive Summary Generator API using Semantic Kernel Function Calling",
    "version": "v1"
  },
  "paths": {
    "/api/summary/generate": {
      "post": {
        "tags": [
          "AdaptiveSummaryGenerator.Api"
        ],
        "operationId": "GenerateAdaptiveSummary",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SummaryGenerationRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/debug/ip": {
      "get": {
        "tags": [
          "AdaptiveSummaryGenerator.Api"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SummaryGenerationRequest": {
        "type": "object",
        "properties": {
          "inputText": {
            "type": "string",
            "nullable": true
          },
          "summaryLength": {
            "enum": [
              "Short",
              "Medium",
              "Detailed"
            ],
            "type": "string"
          },
          "summaryFocus": {
            "enum": [
              "Business",
              "General",
              "KeyPoints",
              "Technical"
            ],
            "type": "string"
          },
          "outputFormat": {
            "enum": [
              "Paragraph",
              "BulletPoints"
            ],
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  }
}